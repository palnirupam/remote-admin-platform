{
  "server": {
    "host": "127.0.0.1",
    "port": 9999,
    "use_tls": true,
    "cert_file": "./certs/dev_server.crt",
    "key_file": "./certs/dev_server.key",
    "max_connections": 100
  },
  "database": {
    "type": "sqlite",
    "path": "./data/remote_system_dev.db"
  },
  "authentication": {
    "secret_key": "dev_secret_key_not_for_production",
    "token_expiry": 86400,
    "enable_token_refresh": true,
    "max_token_age": 604800
  },
  "web_ui": {
    "enabled": true,
    "port": 8080,
    "username": "admin",
    "password": "admin",
    "session_timeout": 7200,
    "enable_2fa": false
  },
  "logging": {
    "level": "DEBUG",
    "file": "./logs/server_dev.log",
    "max_size": 10485760,
    "backup_count": 3,
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "performance": {
    "connection_pool_size": 10,
    "command_queue_size": 50,
    "max_concurrent_transfers": 2,
    "screenshot_rate_limit": 1,
    "enable_caching": false,
    "cache_ttl": 5
  },
  "security": {
    "enable_rate_limiting": false,
    "max_failed_auth_attempts": 10,
    "auth_lockout_duration": 60,
    "enable_ip_whitelist": false,
    "ip_whitelist": [],
    "enable_certificate_pinning": false
  },
  "monitoring": {
    "enable_metrics": true,
    "metrics_port": 9090,
    "enable_prometheus": false,
    "enable_health_check": true,
    "health_check_port": 8081
  }
}
